# Database
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require&channel_binding=require

# JWT Secrets
JWT_SECRET=your-jwt-secret-key
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key

# API Configuration
PORT=3001
NODE_ENV=development
NEXT_PUBLIC_API_URL=https://api.govlearn.ph

# Payment Gateway
PEARLPAY_CODE=VM
PEARLPAY_URL=https://gateway.pearlpay.io
PEARLPAY_TOKEN=your-pearlpay-token
PEARLPAY_REDIRECT_URL=https://govlearn.ph

# Email Configuration
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=govlearn@virtual-mentors.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=govlearn@virtual-mentors.com

# Video Hosting (Mux)
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret

# Upload Thing
UPLOADTHING_TOKEN=your-uploadthing-token

# Additional Configuration
NEXT_PUBLIC_TEACHER_ID=your-teacher-id
NEXT_PUBLIC_PLATFORM_FEE=0.35
NEXT_PUBLIC_APP_URL=https://govlearn.ph
